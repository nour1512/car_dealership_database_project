@page
@model Error200Dealership.Pages.FeedbackPageModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width,initial-scale=1.0">
    <title>Feedback</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <link rel="stylesheet" href="~/css/feedback.css">
    <link rel="shortcut icon" type="image/gif" href="~/logo/Wavy_Tech-16_Single-05.jpg"/>
    <style>
        @@import url('https://fonts.googleapis.com/css2?family=Poppins&display=swap');
        body { margin:0; display:flex; align-items:center; justify-content:space-around; flex-direction:column; min-height:100vh; background:url(/images/welcome-hero/mclaren-gt.jpg) center/cover no-repeat; font-family:'Poppins',sans-serif; padding:30px 0; }
        .textup { text-align:center; color:#000; font-weight:700; }
        i { margin-right:3px; }
        .form-box { background-color:#fff; box-shadow:0 0 10px #000; padding:15px; border-radius:8px; width:500px; max-width:95vw; }
        form { max-width:400px; margin:0 auto; }
        .radio-group { display:flex; margin-bottom:16px; }
        input[type="radio"] { margin-right:8px; }
        label { display:block; margin-bottom:8px; font-size:17px; color:#000; font-weight:600; }
        input, textarea { width:100%; padding:8px; margin-bottom:12px; box-sizing:border-box; border-radius:10px; border:1px solid #ddd; font-family:inherit; }
        button { background-color:#368b44; color:#fff; padding:10px; border:none; border-radius:25px; cursor:pointer; width:100%; font-size:15px; transition:.2s linear; }
        button:hover { background-color:#0a6808; transform:translateY(-3px); }
        h1 { color:#000; }
        .card { max-width:50rem; background:#fff; margin:0 0.2rem; padding:0.2rem; box-shadow:0 0 5px rgba(0,0,0,0.2); width:100%; border-radius:0.5rem; text-align:center; margin-bottom:1rem; display:flex; align-items:center; gap:1rem; }
        .star { font-size:6vh; cursor:pointer; margin-top:0; margin-bottom:0.2rem; color:#ddd; transition:color .15s; }
        .star.active, .star:hover { color:#f8c12f; }
        .floating-tab { position:fixed; bottom:70px; left:50px; right:20px; width:300px; height:200px; background-color:white; border:1px solid #ccc; border-radius:10px; box-shadow:0 4px 6px rgba(0,0,0,0.1); display:none; z-index:1000; flex-direction:column; }
        .tab-content { padding:20px; flex:1; overflow-y:auto; }
        .close-button { position:absolute; top:10px; right:10px; background-color:transparent; border:none; font-size:18px; font-weight:bold; cursor:pointer; color:#333; border-radius:0; padding:0; width:auto; height:auto; }
        .success-msg { background:#d1fae5; color:#065f46; padding:12px; border-radius:6px; margin-bottom:14px; font-weight:600; text-align:center; width:100%; max-width:500px; }
        .error-msg   { background:#fee2e2; color:#991b1b; padding:12px; border-radius:6px; margin-bottom:14px; font-weight:600; text-align:center; width:100%; max-width:500px; }
        .goback-btn { background-color:#A020F0; color:white; padding:10px 20px; border:none; border-radius:5px; font-size:14px; cursor:pointer; margin-top:16px; width:auto; }
        .goback-btn:hover { background-color:#6e3196; transform:none; }
    </style>
</head>
<body>

    @if (!string.IsNullOrEmpty(Model.SuccessMessage))
    {
        <div class="success-msg">@Model.SuccessMessage</div>
    }
    @if (!string.IsNullOrEmpty(Model.ErrorMessage))
    {
        <div class="error-msg">@Model.ErrorMessage</div>
    }

    <h1>Add Feedback</h1>
    <div class="form-box">
        <div class="textup">
            <i class="fa fa-solid fa-clock"></i>
            It only takes two minutes!!
        </div>
        <form method="post" asp-page-handler="Submit">
            <label for="uname">
                <i class="fa fa-solid fa-user"></i>
                Name
            </label>
            <input type="text" id="uname" name="FullName">

            <label for="email">
                <i class="fa fa-solid fa-envelope"></i>
                Email Address
            </label>
            <input type="email" id="email" name="Email">

            <div class="card">
                <h1>Rate</h1>
                <br />
                <span class="star" data-val="1" onclick="gfg(1)">★</span>
                <span class="star" data-val="2" onclick="gfg(2)">★</span>
                <span class="star" data-val="3" onclick="gfg(3)">★</span>
                <span class="star" data-val="4" onclick="gfg(4)">★</span>
                <span class="star" data-val="5" onclick="gfg(5)">★</span>
            </div>
            <input type="hidden" name="Rating" id="ratingVal" value="0" />
            <h3 id="output">Rating is: 0/5</h3>

            <label for="msg">
                <i class="fa-solid fa-comments" style="margin-right:3px"></i>
                Write your Suggestions:
            </label>
            <textarea id="msg" name="Comments" rows="4" cols="10" required></textarea>

            <button type="submit">Submit</button>
        </form>
    </div>

    <!-- Reviews section -->
    @if (Model.Reviews.Count > 0)
    {
        <div style="max-width:500px;width:95%;margin-top:24px">
            <h2 style="color:#fff;text-align:center;margin-bottom:16px">What Customers Say</h2>
            @foreach (var r in Model.Reviews)
            {
                <div style="background:#fff;border-radius:10px;padding:16px;margin-bottom:14px;box-shadow:0 3px 12px rgba(0,0,0,.15)">
                    <div style="color:#f8c12f;font-size:20px;margin-bottom:6px">@(new string('★', r.Rating))@(new string('☆', 5 - r.Rating))</div>
                    <div style="color:#555;font-size:13px;margin-bottom:8px">@(string.IsNullOrEmpty(r.Comments) ? "No comment." : r.Comments)</div>
                    <div style="font-weight:700;color:#07074d;font-size:13px">@(string.IsNullOrEmpty(r.CustomerName) ? "Anonymous" : r.CustomerName)</div>
                    <div style="font-size:11px;color:#aaa">@r.SubmittedAt</div>
                </div>
            }
        </div>
    }

    <div id="floatingTab" class="floating-tab">
        <button class="close-button" onclick="closeTab()">X</button>
        <div class="tab-content">
            <h3>Feedback Recorded</h3>
            <p>Thank you for your feedback! Your input helps us improve.</p>
        </div>
    </div>

    <form method="post" asp-page-handler="GoBack">
        <button type="submit" class="goback-btn">&larr; Go Back</button>
    </form>

    <script src="~/js/jquery.js"></script>
    <script src="~/js/script.js"></script>
    <script>
        let selectedRating = 0;
        function gfg(val) {
            selectedRating = val;
            document.getElementById('ratingVal').value = val;
            document.getElementById('output').innerText = 'Rating is: ' + val + '/5';
            document.querySelectorAll('.star').forEach(function(s, i) {
                s.classList.toggle('active', i < val);
            });
        }
        function closeTab() {
            document.getElementById('floatingTab').style.display = 'none';
        }
    </script>
</body>
</html>
