                </div>
                <div>
                    <nav class="collapse navbar-collapse menu-ui-design" id="navbar-menu">
                        <ul class="nav navbar-nav navbar-right" data-in="fadeInDown" data-out="fadeOutUp">
                            <li class="nav-item"><a href="Customer" class="nav-link">Home Page</a></li>
                            <li class="nav-item"><a href="Customer#service" class="nav-link">Our Services</a></li>
                            <li class="nav-item"><a href="Customer#featured-cars" class="nav-link">Featured Cars</a></li>
                            <li class="nav-item"><a href="Customer#new-cars" class="nav-link">New Cars</a></li>
                            <li class="nav-item active"><a href="#" class="nav-link">Accessories</a></li>
                            <li class="nav-item"><a href="FeedbackPage" class="nav-link">Leave Feedback</a></li>
                            <li class="nav-item"><a href="Customer#contact" class="nav-link">Contact Us</a></li>
                        </ul>
                    </nav>
                </div>
            </div>
        </nav>
    </div>
    <div class="clearfix"></div>
</div>

<br><br><br><br><br><br><br><br>

<section class="accessories-section">
    <div class="container">
        <div class="accessories-header">
            <h2>Car Accessories</h2>
            <p>Explore our range of high-quality car accessories available for purchase.</p>
        </div>

        @if (!string.IsNullOrEmpty(Model.OrderSuccess))
        {
            <div class="success-msg">@Model.OrderSuccess</div>
        }

        <div id="cart" class="container">
            <button class="toggle-button" onclick="toggleTab()">Product List</button>
            <div class="icon-cart">
                <svg aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="none" viewBox="0 0 24 24">
                    <path stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 4h1.5L9 16m0 0h8m-8 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm8 0a2 2 0 1 0 0 4 2 2 0 0 0 0-4Zm-8.5-3h9.25L19 7H7.312"/>
                </svg>
                <span id="cartCount">0</span>
            </div>
            <div id="floatingTab" class="floating-tab">
                <div class="tab-content" style="display:flex;align-items:center;justify-content:space-between;padding-bottom:0">
                    <h1 style="padding:0;margin:0">Shopping Cart</h1>
                    <button onclick="toggleTab()" style="background:none;border:none;font-size:22px;cursor:pointer;color:#333;width:auto;padding:4px 10px;border-radius:50%;line-height:1">&#10005;</button>
                </div>
                <div class="ListCart" id="cartItems">
                </div>
                <div class="tab-buttons">
                    <button class="checkOut" onclick="openCheckout()">CHECK OUT</button>
                </div>
            </div>
        </div>

        <br><br><br><br>

        <!-- Row 1 — DB-driven products -->
        <div class="row" id="productsRow1">
            @foreach (var acc in Model.Accessories.Take(6))
            {
                <div class="col-md-2 accessory-item"
                     data-id="@acc.AccessoryID"
                     data-name="@System.Text.Json.JsonSerializer.Serialize(acc.Name)"
                     data-price="@acc.Price"
                     data-img="~/images/accessories/@System.IO.Path.GetFileName(acc.ImageURL ?? "brush.jpg")">
                    <img src="~/images/accessories/@System.IO.Path.GetFileName(acc.ImageURL ?? "brush.jpg")"
                         alt="@acc.Name"
                         onerror="this.src='~/images/accessories/brush.jpg'" />
                    <div class="accessory-title">@acc.Name</div>
                    <div class="type">@acc.Category</div>
                    <div class="price">$@acc.Price.ToString("N0")</div>
                    <button class="addCart" onclick="addToCart(@acc.AccessoryID)">Add To Cart</button>
                </div>
            }
        </div>

        @if (Model.Accessories.Count > 6)
        {
            <div class="row" id="productsRow2">
                @foreach (var acc in Model.Accessories.Skip(6).Take(6))
                {
                    <div class="col-md-2 accessory-item"
                         data-id="@acc.AccessoryID"
                         data-name="@System.Text.Json.JsonSerializer.Serialize(acc.Name)"
                         data-price="@acc.Price"
                         data-img="~/images/accessories/@System.IO.Path.GetFileName(acc.ImageURL ?? "brush.jpg")">
                        <img src="~/images/accessories/@System.IO.Path.GetFileName(acc.ImageURL ?? "brush.jpg")"
                             alt="@acc.Name"
                             onerror="this.src='~/images/accessories/brush.jpg'" />
                        <div class="accessory-title">@acc.Name</div>
                        <div class="type">@acc.Category</div>
                        <div class="price">$@acc.Price.ToString("N0")</div>
                        <button class="addCart" onclick="addToCart(@acc.AccessoryID)">Add To Cart</button>
                    </div>
                }
            </div>
        }

        @if (Model.Accessories.Count > 12)
        {
            <div class="row" id="productsRow3">
                @foreach (var acc in Model.Accessories.Skip(12))
                {
                    <div class="col-md-2 accessory-item"
                         data-id="@acc.AccessoryID"
                         data-name="@System.Text.Json.JsonSerializer.Serialize(acc.Name)"
                         data-price="@acc.Price"
                         data-img="~/images/accessories/@System.IO.Path.GetFileName(acc.ImageURL ?? "brush.jpg")">
                        <img src="~/images/accessories/@System.IO.Path.GetFileName(acc.ImageURL ?? "brush.jpg")"
                             alt="@acc.Name"
                             onerror="this.src='~/images/accessories/brush.jpg'" />
                        <div class="accessory-title">@acc.Name</div>
                        <div class="type">@acc.Category</div>
                        <div class="price">$@acc.Price.ToString("N0")</div>
                        <button class="addCart" onclick="addToCart(@acc.AccessoryID)">Add To Cart</button>
                    </div>
                }
            </div>
        }

        <br><br><br><br><br>
        <a href="Customer">
            <button id="goback-btnn">GoBack</button>
        </a>
    </div>
</section>

