@page
@model Error200Dealership.Pages.AccessoriesModel
@{
    Layout = null;
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>Car Accessories</title>
    <link href="https://fonts.googleapis.com/css?family=Poppins:400,700" rel="stylesheet">
    <link rel="shortcut icon" type="image/icon" href="~/logo/white favicon error gold.png"/>
    <link rel="stylesheet" href="~/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/linearicons.css">
    <link rel="stylesheet" href="~/css/flaticon.css">
    <link rel="stylesheet" href="~/css/animate.css">
    <link rel="stylesheet" href="~/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/css/owl.theme.default.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/bootsnav.css">
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <style>
        .accessories-section { padding:60px 0; background-color:#f8f9fb; margin-left:30px; margin-right:30px; }
        .accessories-header { text-align:center; margin-bottom:40px; }
        .accessories-header h2 { font-size:36px; font-weight:700; color:#444a57; }
        .accessories-header p { color:#818998; font-size:18px; }
        .accessory-item { text-align:center; margin-bottom:30px; }
        .accessory-item img { max-width:100%; height:auto; border-radius:5px; }
        .accessory-title { font-size:20px; font-weight:500; color:#444a57; margin:10px 0; }
        .availability { font-size:16px; color:#818998; }
        .navbar { background-color:black !important; }
        .navbar-nav > li > a { color:white !important; }
        .navbar-nav > li > a:hover, .navbar-nav > li.active > a { color:#f8c12f !important; }
        .accessory-title { font-size:small; }
        img { filter:drop-shadow(0 50px 20px #0001); }
        button { background-color:#818998; color:#fff; padding:10px; border:none; border-radius:15px; cursor:pointer; width:100%; font-size:15px; transition:.2s linear; }
        #cartbtn { background-color:#f8f9fb; color:#000; }
        #cartbtn span { background-color:#f8f9fb; color:#000; }
        .addCart { background-color:#353; padding:5px 10px; border-radius:20px; margin-top:10px; border:none; cursor:pointer; color:#fff; }
        svg { width:30px; }
        .accessories-section #cart.container { width:900px; max-width:90vw; margin:auto; text-align:right; padding-top:10px; display:flex; align-items:center; padding:20px 0; }
        .icon-cart { position:relative; }
        .icon-cart span { display:flex; width:14px; height:20px; align-items:center; color:#000; border-radius:50%; position:absolute; top:50%; right:-20px; }
        .toggle-button { background-color:#f6f9ff; color:#000; padding:10px 20px; border:none; border-radius:15px; cursor:pointer; font-size:15px; transition:.2s linear; box-shadow:0 4px 6px rgba(0,0,0,0.1); width:10rem; }
        .toggle-button:hover { background-color:#e8ebf3; }
        .floating-tab { position:fixed; bottom:70px; right:20px; width:450px; padding:20px; height:90%; background-color:white; border:1px solid #ccc; border-radius:10px; box-shadow:0 4px 6px rgba(0,0,0,0.1); display:none; z-index:1000; flex-direction:column; justify-content:space-between; grid-template-rows:70px 1fr 70px; }
        .floating-tab h1 { padding:20px; margin:0; font-weight:300; }
        .floating-tab button { background-color:#E88C0E; border:none; font-family:Poppins; font-weight:500; cursor:pointer; }
        .tab-content { padding:20px; flex:1; overflow-y:auto; }
        .tab-buttons { display:flex; justify-content:flex-end; gap:10px; padding:10px 20px; border-top:1px solid #eee; background-color:#f9f9f9; border-radius:0 0 10px 10px; }
        .tab-buttons button { padding:8px 12px; border:none; border-radius:5px; cursor:pointer; background-color:#28a745; color:white; transition:background-color 0.2s ease; }
        .tab-buttons button:hover { background-color:#218838; }
        .ListCart .item img { width:100%; }
        .ListCart .item { display:grid; grid-template-columns:70px 150px 50px 1fr; gap:10px; text-align:center; align-items:center; }
        .ListCart .quantity span { display:inline-block; width:25px; height:25px; background-color:#eee; color:#555; border-radius:50%; cursor:pointer; }
        .ListCart .quantity span:nth-child(2) { background-color:transparent; color:#333; font-weight:600; }
        .ListCart .item:nth-child(even) { background-color:#eee1; }
        .ListCart { overflow:auto; }
        .ListCart::-webkit-scrollbar { width:0; }
        .success-msg { background:#d1fae5; color:#065f46; padding:12px; border-radius:6px; margin:12px 0; font-weight:600; text-align:center; }
        /* Checkout modal */
        .modal-overlay { display:none; position:fixed; inset:0; background:rgba(0,0,0,.5); z-index:10000; align-items:center; justify-content:center; }
        .modal-overlay.open { display:flex; }
        .modal-box { background:#fff; border-radius:12px; padding:32px; width:440px; max-width:95vw; }
        .modal-box h3 { font-size:20px; font-weight:700; color:#07074d; margin-bottom:18px; }
        .modal-input { width:100%; padding:10px 14px; border:1px solid #e0e0e0; border-radius:6px; font-size:14px; margin-bottom:12px; font-family:inherit; outline:none; }
        .modal-input:focus { border-color:#6a64f1; }
        .modal-btns { display:flex; gap:10px; margin-top:6px; }
        .modal-btns button { flex:1; padding:11px; font-size:14px; font-weight:600; border:none; border-radius:8px; cursor:pointer; font-family:inherit; }
        .btn-confirm { background:#28a745; color:white; }
        .btn-cancel  { background:#f3f4f6; color:#333; }
    </style>
</head>
<body>

<!-- Checkout Modal -->
<div class="modal-overlay" id="checkoutModal">
    <div class="modal-box">
        <h3>Complete Your Order</h3>
        <input type="text"  id="orderName"  class="modal-input" placeholder="Your Full Name (optional)" />
        <input type="email" id="orderEmail" class="modal-input" placeholder="Email Address (optional)" />
        <p style="font-size:13px;color:#818998;margin-bottom:14px">Total: <strong id="modalTotal"></strong></p>
        <form method="post" asp-page-handler="PlaceOrder" id="orderForm">
            <input type="hidden" name="CustomerName"  id="hiddenName" />
            <input type="hidden" name="CustomerEmail" id="hiddenEmail" />
            <input type="hidden" name="ItemsJson"     id="hiddenItems" />
            <div class="modal-btns">
                <button type="button" class="btn-cancel" onclick="closeCheckout()">Cancel</button>
                <button type="submit" class="btn-confirm">Place Order</button>
            </div>
        </form>
    </div>
</div>

<!-- Top-area -->
