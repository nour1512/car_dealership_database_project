@page
@model Error200Dealership.Pages.CustomerModel
@{
    Layout = null;
}
<!doctype html>
<html class="no-js" lang="en">
<head>
    <meta charset="utf-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <link href="https://fonts.googleapis.com/css?family=Poppins:100,100i,200,200i,300,300i,400,400i,500,500i,600,600i,700,700i,800,800i,900,900i" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Rufina:400,700" rel="stylesheet">
    <title>Error 200 Showroom</title>
    <link rel="shortcut icon" type="image/icon" href="~/logo/white favicon error gold.png"/>
    <link rel="stylesheet" href="~/css/font-awesome.min.css">
    <link rel="stylesheet" href="~/css/linearicons.css">
    <link rel="stylesheet" href="~/css/flaticon.css">
    <link rel="stylesheet" href="~/css/animate.css">
    <link rel="stylesheet" href="~/css/owl.carousel.min.css">
    <link rel="stylesheet" href="~/css/owl.theme.default.min.css">
    <link rel="stylesheet" href="~/css/bootstrap.min.css">
    <link rel="stylesheet" href="~/css/bootsnav.css">
    <link rel="stylesheet" href="~/css/style.css">
    <link rel="stylesheet" href="~/css/responsive.css">
    <style>
        .db-cars-section { background:#f8f9fb; padding:40px 0; }
        .db-car-card { background:#fff; border-radius:10px; overflow:hidden; box-shadow:0 3px 15px rgba(0,0,0,.08); margin-bottom:24px; transition:.2s; }
        .db-car-card:hover { transform:translateY(-4px); box-shadow:0 10px 30px rgba(0,0,0,.14); }
        .db-car-img { width:100%; height:180px; object-fit:cover; }
        .db-car-img-placeholder { width:100%; height:180px; background:linear-gradient(135deg,#1a1a2e,#07074d); display:flex; align-items:center; justify-content:center; color:#f8c12f; font-size:48px; }
        .db-car-body { padding:16px; }
        .db-car-name { font-size:16px; font-weight:700; color:#07074d; margin-bottom:4px; }
        .db-car-sub  { font-size:12px; color:#818998; margin-bottom:8px; }
        .db-car-price { font-size:18px; font-weight:700; color:#07074d; margin-bottom:10px; }
        .db-car-btn { background:#07074d; color:#fff; border:none; border-radius:5px; padding:8px 14px; font-size:12px; font-weight:600; cursor:pointer; width:100%; transition:.2s; }
        .db-car-btn:hover { background:#f8c12f; color:#000; }
    </style>
</head>
<body>

<!-- Welcome greeting (subtle, inside navbar area) -->
<section id="home" class="welcome-hero">
    <div class="top-area">
        <div class="header-area">
            <nav class="navbar navbar-default bootsnav navbar-sticky navbar-scrollspy" data-minus-value-desktop="70" data-minus-value-mobile="55" data-speed="1000">
                <div class="container">
                    <div class="navbar-header">
                        <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#navbar-menu">
                            <i class="fa fa-bars"></i>
                        </button>
                        <a class="navbar-brand" href="#">Error <sup>200</sup> Dealership<span></span></a>
                    </div>
                    <div>
                        <nav class="collapse navbar-collapse menu-ui-design" id="navbar-menu">
                            <ul class="nav navbar-nav navbar-right" data-in="fadeInDown" data-out="fadeOutUp">
                                <li class="nav-item active"><a href="#home" class="nav-link">Home Page</a></li>
                                <li class="nav-item"><a href="#service" class="nav-link">Our Services</a></li>
                                <li class="nav-item"><a href="#featured-cars" class="nav-link">Featured Cars</a></li>
                                <li class="nav-item"><a href="#new-cars" class="nav-link">New Cars</a></li>
                                <li class="nav-item"><a href="Accessories" class="nav-link">Accessories</a></li>
                                <li class="nav-item"><a href="FeedbackPage" class="nav-link">Leave Feedback</a></li>
                                <li class="nav-item"><a href="OrderHistory" class="nav-link">My Orders</a></li>
                                <li class="nav-item"><a href="#contact" class="nav-link">Contact Us</a></li>
                                <li class="nav-item"><a href="Index" class="nav-link" style="color:#f8c12f">Logout</a></li>
                            </ul>
                        </nav>
                    </div>
                </div>
            </nav>
        </div>
        <div class="clearfix"></div>
    </div>

    <div class="container">
        <div class="welcome-hero-txt">
            <h2>get your desired car for a reasonable price</h2>
            <p>
                At Error <sup>200</sup> Showroom, we redefine luxury on the road. Discover a curated collection of world-class vehicles, where sophistication, performance, and prestige come standard.
            </p>
            <button class="welcome-btn" onclick="window.location.href='Appointments'">Book Appointment</button>
        </div>
    </div>

    <div class="container">
        <div class="row">
            <div class="col-md-11">
                <div class="model-search-content">
                    <div class="row">
                        <div class="col-md-offset-1 col-md-2 col-sm-12">
                            <div class="single-model-search">
                                <h2>select year</h2>
                                <div class="model-select-icon">
                                    <select class="form-control">
                                        <option value="default">year</option>
                                        <option value="2020">2020</option>
                                        <option value="2021">2021</option>
                                        <option value="2022">2022</option>
                                        <option value="2023">2023</option>
                                        <option value="2024">2024</option>
                                    </select>
                                </div>
                            </div>
                            <div class="single-model-search">
                                <h2>body style</h2>
                                <div class="model-select-icon">
                                    <select class="form-control">
                                        <option value="default">style</option>
                                        <option value="muscle">muscle</option>
                                        <option value="sports_car">sports car</option>
                                        <option value="SUV">SUV</option>
                                        <option value="convertible">convertible</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-offset-1 col-md-2 col-sm-12">
                            <div class="single-model-search">
                                <h2>select a price range</h2>
                                <div class="model-select-icon">
                                    <select class="form-control">
                                        <option value="default">price</option>
                                        <option value="$150000">$150,000</option>
                                        <option value="$250000">$250,000</option>
                                        <option value="$350000">$350,000</option>
                                        <option value="$450000">$450,000</option>
                                        <option value="$550000">$550,000</option>
                                    </select>
                                </div>
                            </div>
                            <div class="single-model-search">
                                <h2>select model</h2>
                                <div class="model-select-icon">
                                    <select class="form-control">
                                        <option value="default">model</option>
                                        <option value="bently">Bently</option>
                                        <option value="lamborghini">Lamborghini</option>
                                        <option value="ferrari">Ferrari</option>
                                        <option value="rolls_royce">Rolls-Royce</option>
                                        <option value="maserati">Maserati</option>
                                        <option value="mclaren">Mclaren</option>
                                        <option value="aston_martin">Aston Martin</option>
                                        <option value="jaguar">Jaguar</option>
                                        <option value="porsche">Porsche</option>
                                        <option value="bugatti">Bugatti</option>
                                        <option value="mercedes_benz">Mercedes-Benz</option>
                                    </select>
                                </div>
                            </div>
                        </div>
                        <div class="col-md-5 col-sm-12">
                            <div class="single-model-search text-center">
                                <button class="welcome-btn model-search-btn">search</button>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- service -->
<section id="service" class="service">
    <div class="container">
        <div class="service-content">
            <div class="row">
                <div class="col-md-4 col-sm-6">
                    <div class="single-service-item">
                        <div class="single-service-icon"><i class="flaticon-car"></i></div>
                        <h2><a href="#">largest dealership <span>of</span> car</a></h2>
                        <p>As the largest car dealership in the region, we offer an unparalleled selection of vehicles, ensuring that every customer finds their perfect match.</p>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="single-service-item">
                        <div class="single-service-icon"><i class="flaticon-car-repair"></i></div>
                        <h2><a href="#">unlimited repair warranty</a></h2>
                        <p>Enjoy peace of mind with our unlimited repair warranty, ensuring that your vehicle stays in top condition for as long as you own it.</p>
                    </div>
                </div>
                <div class="col-md-4 col-sm-6">
                    <div class="single-service-item">
                        <div class="single-service-icon"><i class="flaticon-car-1"></i></div>
                        <h2><a href="#">insurance support</a></h2>
                        <p>With our comprehensive insurance support, we make sure you're fully covered, offering seamless assistance for all your vehicle protection needs.</p>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- new-cars -->
<section id="new-cars" class="new-cars">
    <div class="container">
        <div class="section-header">
            <p>checkout <span>the</span> latest cars</p>
            <h2>newest cars</h2>
        </div>
        <div class="new-cars-content">
            <div class="owl-carousel owl-theme" id="new-cars-carousel">
                <div class="new-cars-item">
                    <div class="single-new-cars-item">
                        <div class="row">
                            <div class="col-md-7 col-sm-12">
                                <div class="new-cars-img">
                                    <img src="~/images/new-cars-model/porsche white background high resolution.jpeg" alt="porsche"/>
                                </div>
                            </div>
                            <div class="col-md-5 col-sm-12">
                                <div class="new-cars-txt">
                                    <h2>porsche panamero turbo</h2>
                                    <p>With a powerful turbocharged engine and an unmistakable road presence, the 2022 Panamera Turbo S is Porsche's sporting ethos in four-door form. Unlike the iconic 911 sports car, the Panamera Turbo S sedan has its engine up front — a twin-turbo V-8 making 620 horsepower.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="new-cars-item">
                    <div class="single-new-cars-item">
                        <div class="row">
                            <div class="col-md-7 col-sm-12">
                                <div class="new-cars-img">
                                    <img src="~/images/new-cars-model/lamborghini photo.jpeg" alt="lamborghini"/>
                                </div>
                            </div>
                            <div class="col-md-5 col-sm-12">
                                <div class="new-cars-txt">
                                    <h2>lamborghini huracan</h2>
                                    <p>The Lamborghini Huracan Evo is an experience like no other. From the moment you sit in the driver's seat, the raw power and precision of the car are palpable. The roar of the engine as you accelerate is exhilarating.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="new-cars-item">
                    <div class="single-new-cars-item">
                        <div class="row">
                            <div class="col-md-7 col-sm-12">
                                <div class="new-cars-img">
                                    <img src="~/images/new-cars-model/Mansory rolls grey background.jpg" alt="rolls royce"/>
                                </div>
                            </div>
                            <div class="col-md-5 col-sm-12">
                                <div class="new-cars-txt">
                                    <h2>rolls-royce dawn</h2>
                                    <p>The Rolls-Royce Dawn carries all the characteristics of any other car from the brand — comfort, luxury and power in spades. What you must always remember about a Rolls-Royce is that it always ensures the owner is in as much comfort as possible.</p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

<!-- featured-cars (static original + DB cars) -->
